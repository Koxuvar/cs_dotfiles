* {
    bg: #1d2021;
    bg1: #282828;
    fg: #d4be98;
    accent: #a9b665;

    background-color: @bg;
    text-color: @fg;
}

window {
    width: 420px;
    border-radius: 6px;
    background-color: @bg;
}

inputbar {
    padding: 10px;
    background-color: @bg1;
}

listview {
    padding: 8px;
}

element selected {
    background-color: @bg1;
    text-color: @accent;
}

entry, prompt {
    text-color: @fg;
}
